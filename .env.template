# ── RAG Bot — environment template ────────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env.
#
# Auth notes (production):
#   - AZURE_OPENAI_API_KEY, AZURE_SEARCH_API_KEY, COSMOS_KEY must be ABSENT
#     in production ACA environment variables. Their absence forces managed-
#     identity auth, which is the correct production path.
#   - Only MicrosoftAppPassword cannot use managed identity (Bot Framework
#     requirement). Store it in Key Vault and reference via ACA secret ref.
# ──────────────────────────────────────────────────────────────────────────────

# ── Deployment environment ─────────────────────────────────────────────────────
# Values: development | staging | production
# In production ACA: set to "production" (test endpoints will be disabled).
ENVIRONMENT=production

# ── Azure AI Foundry ───────────────────────────────────────────────────────────
# Portal: AI Foundry → your project → Overview → Project endpoint
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>

# Portal: AI Foundry → your project → Deployments tab → Target URI (openai.azure.com)
# Used for managed-identity auth (production).
AZURE_OPENAI_ENDPOINT=https://<your-hub>.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-41-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Claude (complex query routing via Azure AI Foundry) ────────────────────────
# Portal: AI Foundry → your project → Deployments → Claude → Target URI
# Format: https://<resource>.services.ai.azure.com/anthropic
# Leave blank to disable Claude routing (all synthesis uses AZURE_OPENAI_CHAT_DEPLOYMENT).
# Production auth: DefaultAzureCredential (managed identity) — no API key needed.
# Required RBAC: "Azure AI Developer" role on the AI Foundry resource.
CLAUDE_ENDPOINT=https://<resource>.services.ai.azure.com/anthropic
# Deployment name exactly as shown in AI Foundry → Deployments tab.
CLAUDE_CHAT_DEPLOYMENT=claude-sonnet-4-6

# LOCAL DEV ONLY — required when AZURE_OPENAI_API_KEY is set.
# Portal: AI Foundry → your project → Overview → Endpoint (cognitiveservices.azure.com)
# API-key auth requires this endpoint; leave blank in staging/production.
AZURE_OPENAI_COGNITIVESERVICES_ENDPOINT=https://<your-hub>.cognitiveservices.azure.com/

# LOCAL DEV ONLY — leave blank in staging/production (managed identity is used instead)
AZURE_OPENAI_API_KEY=

# ── Azure AI Search ────────────────────────────────────────────────────────────
# Portal: AI Search → Overview → URL
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_INDEX=idx-rag
AZURE_SEARCH_SEMANTIC_CONFIG=rag-semantic-config

# LOCAL DEV ONLY — leave blank in staging/production
# Portal: AI Search → Settings → Keys → Primary admin key
AZURE_SEARCH_API_KEY=

# ── Cosmos DB ──────────────────────────────────────────────────────────────────
# Portal: Cosmos DB → Overview → URI
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_DATABASE=csmsdb-aishrdsvcs-eus-prod

# Container names (must match scripts/setup_cosmos.py provisioning)
COSMOS_CONTAINER_CHAT=chat-history
COSMOS_CONTAINER_FEEDBACK=feedback
COSMOS_CONTAINER_SESSIONS=sessions
COSMOS_CONTAINER_LTM=long-term-memory

# LOCAL DEV ONLY — leave blank in staging/production
# Portal: Cosmos DB → Settings → Keys → Primary key
COSMOS_KEY=

# ── Microsoft Bot Framework ────────────────────────────────────────────────────
# Portal: Azure Bot → Configuration
MicrosoftAppId=<bot-app-registration-client-id>
MicrosoftAppType=SingleTenant
MicrosoftAppTenantId=<your-tenant-id>

# Store in Key Vault in production — reference via ACA secret ref.
# Portal: Azure Bot → Configuration → Microsoft App Password
MicrosoftAppPassword=<bot-app-secret>

# ── Inter-agent auth ───────────────────────────────────────────────────────────
# Shared secret sent as X-Internal-Secret header between agents.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Required in staging/production. Can be left empty in local dev.
# Store in Key Vault — reference via ACA secret ref.
INTERNAL_API_SECRET=

# ── Service Bus (escalation) ───────────────────────────────────────────────────
# ── Zendesk (primary escalation channel) ──────────────────────────────────────
# Admin Centre → Apps and integrations → APIs → Zendesk API → Token access
# ZENDESK_SUBDOMAIN : the part before .zendesk.com  e.g. "mycompany"
# ZENDESK_API_TOKEN : API token (not the password)
# ZENDESK_USER_EMAIL: the agent account used for API calls (ticket:write required)
# ZENDESK_GROUP_ID_TICKET: optional — Zendesk group ID for ticket routing
# ZENDESK_GROUP_ID_SME   : optional — Zendesk group ID for SME-connection routing
ZENDESK_SUBDOMAIN=
ZENDESK_API_TOKEN=
ZENDESK_USER_EMAIL=
ZENDESK_GROUP_ID_TICKET=
ZENDESK_GROUP_ID_SME=

# ── Azure Service Bus (escalation fallback — used only when Zendesk is not set)
# Production: set AZURE_SERVICE_BUS_NAMESPACE only (managed identity).
# Portal: Service Bus → Overview → Host name
AZURE_SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net

# LOCAL DEV ONLY — leave blank in staging/production.
# Portal: Service Bus → Shared access policies → Primary connection string
AZURE_SERVICE_BUS_CONNECTION_STR=

# Queue name for escalation messages (must match provisioned queue)
SB_QUEUE_ESCALATION=escalation-requests

# ── Agent URLs (internal, set per ACA app) ─────────────────────────────────────
# Teams Bot needs to reach Main Agent:
MAIN_AGENT_URL=http://localhost:8000
# Main Agent needs to reach Orchestrator:
ORCHESTRATOR_URL=http://localhost:8001
# Orchestrator needs to reach Retrieval Agent:
RETRIEVAL_URL=http://localhost:8002

# ── Service ports ──────────────────────────────────────────────────────────────
BOT_PORT=3978

# ── RAG tuning ─────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75
MAX_RETRIEVAL_ATTEMPTS=3
RETRIEVAL_TOP_K=5
SYNTHESIS_TEMPERATURE=0.0
MAX_QUERY_LENGTH=2000
# Max tokens the synthesis LLM may generate. Must cover the full JSON envelope.
# Set to at least SYNTHESIS_MAX_ANSWER_CHARS / 4 (chars-to-tokens ratio).
SYNTHESIS_MAX_TOKENS=3000

# ── Memory ─────────────────────────────────────────────────────────────────────
SESSION_MAX_TURNS=10
SESSION_TTL_SECONDS=604800
LTM_SUMMARY_EVERY_N=5
LTM_MAX_SUMMARY_CHARS=3000
LTM_MAX_FACTS=10

# ── Redis (distributed rate limiting) ─────────────────────────────────────────
# Set to enable multi-replica-safe rate limiting. Leave blank for single-worker
# in-process fallback (a WARNING is logged when REDIS_URL is absent).
# Portal: Azure Cache for Redis → Overview → Host name
# Format: rediss://<name>.redis.cache.windows.net:6380?ssl=true&password=<key>
REDIS_URL=

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=20
RATE_LIMIT_BURST=5

# ── Domain classification ──────────────────────────────────────────────────────
DOMAIN_CONFIDENCE_THRESHOLD=0.6

# ── Observability ──────────────────────────────────────────────────────────────
# Portal: Application Insights → Overview → Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_LEVEL=INFO

# ── Ingestion pipeline (separate service — kept here for unified reference) ────
AZURE_STORAGE_ACCOUNT_NAME=<storage-account-name>
AZURE_STORAGE_CONTAINER_RAW=raw-documents
AZURE_STORAGE_CONTAINER_PROCESSED=processed-chunks

# SharePoint connector
SHAREPOINT_TENANT_ID=<tenant-id>
SHAREPOINT_CLIENT_ID=<app-client-id>
SHAREPOINT_CLIENT_SECRET=<client-secret>
SHAREPOINT_WEBHOOK_SECRET=changeme-use-a-random-string
SHAREPOINT_DEFAULT_SITE_ID=

# Site → domain mapping: <sharepoint-site-id>:hr,<another-site-id>:legal
SITE_DOMAIN_MAP=

# Ingestion processing tuning
CHILD_CHUNK_MAX_TOKENS=200
PARENT_CHUNK_MAX_TOKENS=1000
HEADER_FOOTER_MARGIN_PCT=0.07
AZURE_OPENAI_LIGHT_LLM_DEPLOYMENT=gpt-4o-mini

# Ingestion Service Bus queues
SB_QUEUE_INGESTION=ingestion-tasks
SB_QUEUE_PROCESSING=processing-tasks
SB_QUEUE_EMBEDDING=embedding-tasks
