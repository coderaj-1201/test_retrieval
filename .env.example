# ── Copy this file to .env and fill in your values for local development ──────
# For production (Azure Container Apps), set these as ACA environment variables.
# DO NOT commit a populated .env file to source control.

# ── Deployment environment ─────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Azure AI Foundry ───────────────────────────────────────────────────────────
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://your-project.api.azureml.ms
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-41-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Claude (complex query routing via Azure AI Foundry) ────────────────────────
# Set CLAUDE_ENDPOINT to enable Claude for complex queries. Leave blank to
# route all synthesis through AZURE_OPENAI_CHAT_DEPLOYMENT instead.
# In production (ACA) authentication uses DefaultAzureCredential (managed identity)
# — no API key is required. Assign the managed identity the "Azure AI Developer"
# role on the Azure AI Foundry resource.
# Endpoint format: https://<resource>.services.ai.azure.com/anthropic
CLAUDE_ENDPOINT=https://aifoundry-aishrdsvcs-eus2-prod.services.ai.azure.com/anthropic
CLAUDE_CHAT_DEPLOYMENT=claude-sonnet-4-6

# ── Azure AI Search ────────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_INDEX=idx-rag
AZURE_SEARCH_SEMANTIC_CONFIG=rag-semantic-config

# ── Cosmos DB ──────────────────────────────────────────────────────────────────
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE=csmsdb-aishrdsvcs-eus-prod
COSMOS_CONTAINER_CHAT=chat-history
COSMOS_CONTAINER_FEEDBACK=feedback
COSMOS_CONTAINER_SESSIONS=sessions
COSMOS_CONTAINER_LTM=long-term-memory

# ── Inter-agent URLs (local dev: all on localhost) ────────────────────────────
MAIN_AGENT_URL=http://localhost:8000
ORCHESTRATOR_URL=http://localhost:8001
RETRIEVAL_URL=http://localhost:8002

# ── Inter-agent auth ───────────────────────────────────────────────────────────
# Leave empty for local dev; set a strong random value in ACA.
INTERNAL_API_SECRET=

# ── Teams Bot ──────────────────────────────────────────────────────────────────
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TYPE=MultiTenant
MICROSOFT_APP_TENANT_ID=
BOT_PORT=3978

# ── Service Bus ────────────────────────────────────────────────────────────────
AZURE_SERVICE_BUS_NAMESPACE=
SB_QUEUE_ESCALATION=escalation-requests

# ── Zendesk ────────────────────────────────────────────────────────────────────
ZENDESK_SUBDOMAIN=
ZENDESK_API_TOKEN=
ZENDESK_USER_EMAIL=
ZENDESK_GROUP_ID_TICKET=
ZENDESK_GROUP_ID_SME=

# ── RAG tuning ─────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.65
CITATION_CONFIDENCE_THRESHOLD=0.40
MAX_RETRIEVAL_ATTEMPTS=3
RETRIEVAL_TOP_K=5
SYNTHESIS_TEMPERATURE=0.0
MAX_QUERY_LENGTH=2000
SYNTHESIS_MAX_CONTEXT_CHARS=12000
SYNTHESIS_MAX_SOURCES=5
SYNTHESIS_MAX_ANSWER_CHARS=10000
SYNTHESIS_MAX_TOKENS=6000

# ── Memory ─────────────────────────────────────────────────────────────────────
SESSION_MAX_TURNS=10
SESSION_TTL_SECONDS=604800
LTM_SUMMARY_EVERY_N=5
LTM_MAX_SUMMARY_CHARS=3000
LTM_MAX_FACTS=10

# ── Rate limiting ──────────────────────────────────────────────────────────────
REDIS_URL=
RATE_LIMIT_RPM=20
RATE_LIMIT_BURST=5

# ── Domain classification ──────────────────────────────────────────────────────
DOMAIN_CONFIDENCE_THRESHOLD=0.6

# ── Escalation SLAs ────────────────────────────────────────────────────────────
ESCALATION_SLA_TICKET=4 business hours
ESCALATION_SLA_SME=2 business hours

# ── Observability ──────────────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_LEVEL=INFO
